<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>dotnet-ode</PackageId>
    <Version>0.1.6</Version>
    <Authors>ÂnimaLab</Authors>
    <Company>ÂnimaLab</Company>
    <Description>Opinionated delivery engine for .NET applications.</Description>
    <PackageTags>ode;dotnet;architecture;usecase;mvvm;workflow;delivery-engine</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/animalab-netizen/dotnet-ode</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/animalab-netizen/dotnet-ode</PackageProjectUrl>
    <PackageReleaseNotes>Publishes dotnet-ode through a release workflow decoupled from CI test execution, while CI keeps validating the runtime on main and pull requests.</PackageReleaseNotes>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
